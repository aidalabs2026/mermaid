---
import { SITE_NAME, FOOTER_LINKS } from '~/consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <strong>{SITE_NAME}</strong> &copy; {year}
      <div class="disclaimer">
        Diagrams are rendered in your browser by Mermaid.js. Always check the
        rendered output before using a diagram in production documentation.
      </div>
    </div>
    <nav class="footer-links" aria-label="Legal">
      {FOOTER_LINKS.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</footer>
