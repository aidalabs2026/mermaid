---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you were looking for could not be found." noindex>
  <div class="prose" style="text-align: center;">
    <h1>404 — Not found</h1>
    <p>The page you were looking for doesn't exist or has moved.</p>
    <p>
      <a class="btn btn-primary" href="/">Go home</a>
      <a class="btn" href="/preview/" style="margin-left: 0.5rem;">Open the preview</a>
    </p>
  </div>
</BaseLayout>
