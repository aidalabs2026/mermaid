---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { CONTACT_EMAIL, SITE_NAME, SITE_URL } from '~/consts';
const sent = Astro.url.searchParams.get('sent') === '1';
---

<BaseLayout
  title="Contact"
  description={`Send feedback, report a bug, or ask a question about ${SITE_NAME}.`}
>
  <article class="prose">
    <h1>Contact</h1>

    {sent && (
      <div class="callout callout-tip">
        <div class="callout-title">Thanks — message received</div>
        We will get back to you at the email address you provided. If you
        don't see a reply within a few days, please check your spam folder.
      </div>
    )}

    <p>
      Bug report, feature request, or general feedback — we read every
      message. The form below forwards directly to our inbox via FormSubmit.
      You can also email us at
      <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a> if you prefer.
    </p>

    <form
      action={`https://formsubmit.co/${CONTACT_EMAIL}`}
      method="POST"
      class="contact-form"
    >
      <input type="hidden" name="_subject" value={`[${SITE_NAME}] Contact form`} />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_next" value={`${SITE_URL}/contact/?sent=1`} />
      <input
        type="text"
        name="_honey"
        style="display:none"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <div class="form-field">
        <label for="f-name">Name</label>
        <input type="text" id="f-name" name="name" required autocomplete="name" />
      </div>

      <div class="form-field">
        <label for="f-email">Email</label>
        <input type="email" id="f-email" name="email" required autocomplete="email" />
      </div>

      <div class="form-field">
        <label for="f-topic">Topic</label>
        <select id="f-topic" name="topic">
          <option>General feedback</option>
          <option>Bug report</option>
          <option>Feature request</option>
          <option>Diagram rendering issue</option>
          <option>Privacy or legal question</option>
          <option>Other</option>
        </select>
      </div>

      <div class="form-field">
        <label for="f-message">Message</label>
        <textarea id="f-message" name="message" rows="7" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Send message</button>
    </form>

    <h2>What to expect</h2>
    <ul>
      <li>We respond within a few business days.</li>
      <li>
        For rendering bug reports, please include the Mermaid source that
        reproduces the issue and the browser/OS you are using. Redact
        anything sensitive — many diagrams in production documentation are
        confidential.
      </li>
      <li>
        For privacy requests (see our <a href="/privacy/">Privacy Policy</a>),
        please mention the applicable regulation (GDPR, CCPA, etc.) so we can
        respond appropriately.
      </li>
    </ul>
  </article>

  <style>
    .contact-form select {
      width: 100%;
      padding: 0.55rem 0.7rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      background: var(--color-surface);
      color: var(--color-text);
      font: inherit;
    }
    .contact-form textarea { resize: vertical; }
  </style>
</BaseLayout>
