---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE_NAME, SITE_URL } from '~/consts';

export async function getStaticPaths() {
  const all = await getCollection('guides', ({ data }) => data.draft !== true);
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.lastUpdated.toISOString(),
  dateModified: entry.data.lastUpdated.toISOString(),
  author: { '@type': 'Organization', name: SITE_NAME },
  publisher: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL + '/' },
  mainEntityOfPage: SITE_URL + `/guides/${entry.id}/`,
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.ogImage}
>
  <article class="prose">
    <p><a href="/guides/">← All guides</a></p>
    <h1>{entry.data.title}</h1>
    <p><em>Last updated: {entry.data.lastUpdated.toISOString().slice(0, 10)}</em></p>

    <Content />

    <hr />
    <p>
      <a href="/preview/">Open the live preview</a> ·
      <a href="/diagrams/">Diagram types</a> ·
      <a href="/guides/">More guides</a>
    </p>

    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  </article>
</BaseLayout>
