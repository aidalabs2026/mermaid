---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE_NAME, SITE_URL } from '~/consts';
import { MERMAID_EXAMPLES } from '~/lib/examples';

const toolJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: `${SITE_NAME} — Live Preview`,
  alternateName: 'Mermaid Diagram Live Editor',
  description:
    'Free browser-based Mermaid diagram preview. Paste Mermaid syntax and see a rendered SVG instantly. Export SVG or PNG, copy a shareable URL, and pick from four built-in themes. Renders entirely in your browser.',
  url: SITE_URL + '/preview/',
  applicationCategory: 'DeveloperApplication',
  applicationSubCategory: 'DiagrammingTool',
  operatingSystem: 'Any (modern web browser)',
  browserRequirements: 'Requires JavaScript. Requires HTML5.',
  inLanguage: 'en',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  featureList: [
    'Live render of Mermaid diagrams as you type',
    'Eleven supported diagram types: flowchart, sequence, class, state, ER, gantt, pie, mindmap, journey, gitGraph, timeline',
    'Built-in themes: default, dark, forest, neutral',
    'Export rendered diagram as SVG or PNG',
    'Copy SVG markup or PNG image to clipboard',
    'Shareable URL encodes diagram in the URL fragment (never sent to server)',
    'Strict-mode sanitisation against script injection',
    'Keyboard shortcuts',
  ],
  isAccessibleForFree: true,
};

const exampleList = MERMAID_EXAMPLES;
---

<BaseLayout
  title="Live Mermaid Preview"
  description="Paste Mermaid syntax and see a rendered SVG diagram instantly. Pick a theme, export SVG or PNG, share a URL — all without leaving your browser."
>
  <div class="tool-page">
    <div class="container tool-head">
      <span class="privacy-badge">🔒 Your diagram never leaves your browser</span>
      <h1>Live Mermaid Preview</h1>
      <p class="tool-intro">
        Type Mermaid syntax on the left, see the rendered diagram on the right.
        Use <strong>Examples</strong> to load a sample for any diagram type, or
        paste your own. The render runs locally in <code>strict</code> mode —
        no server, no surprises.
      </p>
    </div>

    <div class="container">
      <div class="editor-grid">
        <section class="editor-pane" aria-labelledby="input-label">
          <div class="pane-head">
            <label id="input-label" for="input">Mermaid syntax</label>
            <div class="pane-actions">
              <div class="dropdown">
                <button type="button" class="btn btn-sm" id="examples-btn" aria-haspopup="menu" aria-expanded="false">
                  Examples ▾
                </button>
                <ul class="dropdown-menu" id="examples-menu" role="menu" hidden>
                  {exampleList.map((ex) => (
                    <li role="menuitem">
                      <button type="button" data-example-key={ex.key}>{ex.label}</button>
                    </li>
                  ))}
                </ul>
              </div>
              <button type="button" class="btn btn-sm" id="clear-btn">Clear</button>
            </div>
          </div>
          <textarea
            id="input"
            class="editor-textarea"
            spellcheck="false"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            placeholder={`Paste Mermaid syntax here, for example:\n\nflowchart TD\n  A[Start] --> B{Decision?}\n  B -- Yes --> C[Do thing]\n  B -- No --> D[Skip]\n  C --> E[Done]\n  D --> E`}
          ></textarea>
          <div class="pane-meta" id="input-meta"></div>
        </section>

        <section class="editor-pane preview-pane" aria-labelledby="output-label">
          <div class="pane-head">
            <label id="output-label">Preview</label>
            <div class="pane-actions">
              <button type="button" class="btn btn-sm" id="copy-svg-btn" disabled>Copy SVG</button>
              <button type="button" class="btn btn-sm" id="download-svg-btn" disabled>SVG</button>
              <button type="button" class="btn btn-sm" id="download-png-btn" disabled>PNG</button>
            </div>
          </div>
          <div id="preview" class="preview-canvas" role="img" aria-label="Rendered Mermaid diagram">
            <div class="preview-empty">Start typing or pick an example.</div>
          </div>
          <div class="pane-meta" id="output-meta"></div>
        </section>
      </div>

      <div class="toolbar">
        <div class="toolbar-buttons">
          <button type="button" class="btn btn-primary" id="render-btn">Render</button>
        </div>
        <div class="toolbar-options">
          <label>
            Theme:
            <select id="theme-select">
              <option value="default" selected>default</option>
              <option value="dark">dark</option>
              <option value="forest">forest</option>
              <option value="neutral">neutral</option>
            </select>
          </label>
          <button type="button" class="btn btn-sm" id="share-btn">Copy share URL</button>
        </div>
      </div>

      <div id="status-bar" class="status-bar status-idle" role="status" aria-live="polite">
        Ready. Keyboard: <kbd>Ctrl</kbd>+<kbd>Enter</kbd> Render · <kbd>Ctrl</kbd>+<kbd>S</kbd> SVG · <kbd>Ctrl</kbd>+<kbd>Shift</kbd>+<kbd>S</kbd> PNG · <kbd>Ctrl</kbd>+<kbd>K</kbd> Clear · <kbd>Ctrl</kbd>+<kbd>.</kbd> Examples
      </div>
    </div>

    <noscript>
      <div class="container">
        <div class="callout callout-warning">
          This tool requires JavaScript to run. Please enable JavaScript in your browser.
        </div>
      </div>
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(toolJsonLd)} />

    <section class="prose">
      <h2>What is Mermaid?</h2>
      <p>
        <a href="https://mermaid.js.org/" rel="nofollow noopener">Mermaid</a> is
        a JavaScript library that turns short text descriptions into rendered
        diagrams. GitHub, GitLab, Notion, Obsidian, Hugo, Jekyll, and many
        documentation tools render Mermaid blocks automatically, which is why
        it has become the de-facto "diagrams as code" syntax.
      </p>

      <h2>What you can do here</h2>
      <ul>
        <li><strong>Render</strong> any of the eleven Mermaid diagram types as you type.</li>
        <li><strong>Switch themes</strong> between default, dark, forest, and neutral.</li>
        <li><strong>Export</strong> the result as SVG (vector) or PNG (raster).</li>
        <li><strong>Share</strong> a URL that encodes the diagram in the fragment — the diagram source never reaches our server.</li>
        <li><strong>Learn</strong> from the per-type guides under <a href="/diagrams/">Diagrams</a>.</li>
      </ul>

      <h2>Privacy notes</h2>
      <p>
        Rendering runs entirely in your browser. The Mermaid library is bundled
        from <code>node_modules</code> at build time, not fetched from a CDN at
        runtime. The "Copy share URL" feature stores the diagram in the URL
        fragment (<code>#code=...</code>); fragments are never transmitted to
        the server, so your diagram source is not in our access logs.
        See our <a href="/privacy/">Privacy Policy</a>.
      </p>
    </section>
  </div>

  <style>
    .tool-page { padding: 1.5rem 0 3rem; }
    .tool-head {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }
    .tool-head h1 { margin: 0.1em 0 0.25em; font-size: 1.9rem; }
    .tool-intro { color: var(--color-text-muted); margin: 0; max-width: 780px; }

    .editor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      height: clamp(480px, calc(100vh - 340px), 820px);
    }
    .editor-pane {
      display: flex;
      flex-direction: column;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      overflow: hidden;
      min-height: 0;
    }
    .pane-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid var(--color-border);
      background: var(--color-bg-alt);
      font-size: 0.9rem;
      font-weight: 500;
    }
    .pane-head label { font-weight: 600; }
    .pane-actions { display: flex; gap: 0.35rem; align-items: center; }
    .dropdown { position: relative; display: inline-block; }
    .dropdown-menu {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      min-width: 220px;
      max-height: 360px;
      overflow-y: auto;
      list-style: none;
      margin: 0;
      padding: 0.25rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-md);
      z-index: 20;
    }
    .dropdown-menu li button {
      display: block;
      width: 100%;
      text-align: left;
      padding: 0.4rem 0.6rem;
      background: transparent;
      border: 0;
      color: var(--color-text);
      font: inherit;
      font-size: 0.9rem;
      border-radius: var(--radius-sm);
      cursor: pointer;
    }
    .dropdown-menu li button:hover { background: var(--color-bg-alt); }

    .editor-textarea {
      flex: 1 1 auto;
      min-height: 0;
      height: 100%;
      width: 100%;
      resize: none;
      border: 0;
      padding: 0.9rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--color-text);
      background: var(--color-surface);
      white-space: pre;
      tab-size: 2;
    }
    .editor-textarea:focus { outline: 2px solid var(--color-accent); outline-offset: -2px; }

    .preview-pane .preview-canvas {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      padding: 1rem;
      background: var(--color-surface);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .preview-canvas svg { max-width: 100%; height: auto; }
    .preview-empty {
      color: var(--color-text-muted);
      font-size: 0.95rem;
      text-align: center;
    }

    .pane-meta {
      padding: 0.4rem 0.75rem;
      font-size: 0.8rem;
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
      background: var(--color-bg-alt);
      min-height: 1.75rem;
    }

    .toolbar {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin: 1rem 0 0.5rem;
    }
    .toolbar-buttons, .toolbar-options {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .toolbar-options label {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }
    .toolbar-options select {
      padding: 0.35rem 0.5rem;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      background: var(--color-surface);
      color: var(--color-text);
      font: inherit;
      font-size: 0.9rem;
    }

    .status-bar {
      padding: 0.6rem 0.85rem;
      border-radius: var(--radius-sm);
      font-size: 0.88rem;
      border: 1px solid var(--color-border);
      background: var(--color-bg-alt);
      color: var(--color-text-muted);
    }
    .status-bar kbd {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-bottom-width: 2px;
      border-radius: 3px;
      padding: 0 0.3rem;
      color: var(--color-text);
    }
    .status-success { border-color: var(--color-success); background: var(--color-success-bg); color: var(--color-success); }
    .status-error { border-color: var(--color-error); background: var(--color-error-bg); color: var(--color-error); }

    @media (max-width: 820px) {
      .editor-grid {
        grid-template-columns: 1fr;
        height: auto;
      }
      .editor-pane { height: 60vh; min-height: 340px; }
    }
  </style>

  <script>
    import { MERMAID_EXAMPLES } from '~/lib/examples';
    import LZString from 'lz-string';

    const RENDER_DEBOUNCE_MS = 300;

    const input = document.getElementById('input') as HTMLTextAreaElement;
    const preview = document.getElementById('preview') as HTMLElement;
    const renderBtn = document.getElementById('render-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const examplesBtn = document.getElementById('examples-btn') as HTMLButtonElement;
    const examplesMenu = document.getElementById('examples-menu') as HTMLUListElement;
    const themeSelect = document.getElementById('theme-select') as HTMLSelectElement;
    const shareBtn = document.getElementById('share-btn') as HTMLButtonElement;
    const copySvgBtn = document.getElementById('copy-svg-btn') as HTMLButtonElement;
    const downloadSvgBtn = document.getElementById('download-svg-btn') as HTMLButtonElement;
    const downloadPngBtn = document.getElementById('download-png-btn') as HTMLButtonElement;
    const statusBar = document.getElementById('status-bar') as HTMLElement;
    const inputMeta = document.getElementById('input-meta') as HTMLElement;
    const outputMeta = document.getElementById('output-meta') as HTMLElement;

    type Theme = 'default' | 'dark' | 'forest' | 'neutral';

    let mermaidLib: typeof import('mermaid').default | null = null;
    let renderTimer: number | null = null;
    let lastSvg: string = '';
    let renderId = 0;

    async function getMermaid(): Promise<typeof import('mermaid').default> {
      if (!mermaidLib) {
        const mod = await import('mermaid');
        mermaidLib = mod.default;
      }
      mermaidLib.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: themeSelect.value as Theme,
      });
      return mermaidLib;
    }

    function setStatus(kind: 'idle' | 'success' | 'error', html: string) {
      statusBar.className = 'status-bar ' + (
        kind === 'success' ? 'status-success'
        : kind === 'error' ? 'status-error'
        : 'status-idle'
      );
      statusBar.innerHTML = html;
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function updateInputMeta() {
      const text = input.value;
      const lines = text ? text.split('\n').length : 0;
      const bytes = new TextEncoder().encode(text).length;
      inputMeta.textContent = text
        ? `${lines.toLocaleString()} line${lines === 1 ? '' : 's'} · ${bytes} B`
        : '';
    }

    async function render() {
      const text = input.value.trim();
      if (!text) {
        preview.innerHTML = '<div class="preview-empty">Start typing or pick an example.</div>';
        outputMeta.textContent = '';
        lastSvg = '';
        copySvgBtn.disabled = true;
        downloadSvgBtn.disabled = true;
        downloadPngBtn.disabled = true;
        setStatus('idle', 'Ready.');
        return;
      }

      const myId = ++renderId;
      setStatus('idle', '<strong>Rendering…</strong>');

      try {
        const m = await getMermaid();
        const start = performance.now();
        const id = `mermaid-${myId}`;
        const { svg } = await m.render(id, text);
        if (myId !== renderId) return; // a newer render started

        preview.innerHTML = svg;
        lastSvg = svg;
        const elapsed = performance.now() - start;
        outputMeta.textContent = `Rendered in ${elapsed.toFixed(1)} ms`;
        copySvgBtn.disabled = false;
        downloadSvgBtn.disabled = false;
        downloadPngBtn.disabled = false;
        setStatus('success', `✓ Rendered in ${elapsed.toFixed(1)} ms`);
      } catch (err) {
        if (myId !== renderId) return;
        const raw = err instanceof Error ? err.message : String(err);
        const firstLine = raw.split('\n')[0].trim();
        preview.innerHTML = '<div class="preview-empty">Could not render. See message below.</div>';
        outputMeta.textContent = '';
        lastSvg = '';
        copySvgBtn.disabled = true;
        downloadSvgBtn.disabled = true;
        downloadPngBtn.disabled = true;
        setStatus('error', `✗ ${escapeHtml(firstLine)}`);
      }
    }

    function scheduleRender() {
      if (renderTimer !== null) window.clearTimeout(renderTimer);
      renderTimer = window.setTimeout(render, RENDER_DEBOUNCE_MS);
    }

    function clearAll() {
      input.value = '';
      preview.innerHTML = '<div class="preview-empty">Start typing or pick an example.</div>';
      outputMeta.textContent = '';
      inputMeta.textContent = '';
      lastSvg = '';
      copySvgBtn.disabled = true;
      downloadSvgBtn.disabled = true;
      downloadPngBtn.disabled = true;
      setStatus('idle', 'Cleared.');
      input.focus();
    }

    async function copySvg() {
      if (!lastSvg) return;
      try {
        await navigator.clipboard.writeText(lastSvg);
        setStatus('success', '✓ SVG copied to clipboard');
      } catch {
        setStatus('error', 'Clipboard write failed.');
      }
    }

    function downloadBlob(blob: Blob, filename: string) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function downloadSvg() {
      if (!lastSvg) return;
      downloadBlob(new Blob([lastSvg], { type: 'image/svg+xml;charset=utf-8' }), 'diagram.svg');
      setStatus('success', '✓ SVG downloaded');
    }

    async function downloadPng() {
      if (!lastSvg) return;
      try {
        const blob = await svgToPng(lastSvg, 2);
        downloadBlob(blob, 'diagram.png');
        setStatus('success', '✓ PNG downloaded');
      } catch (err) {
        const raw = err instanceof Error ? err.message : String(err);
        setStatus('error', `✗ PNG export failed: ${escapeHtml(raw)}`);
      }
    }

    async function svgToPng(svg: string, scale: number): Promise<Blob> {
      const svgEl = preview.querySelector('svg');
      let width = 800;
      let height = 600;
      if (svgEl) {
        const rect = svgEl.getBoundingClientRect();
        width = Math.max(1, Math.round(rect.width));
        height = Math.max(1, Math.round(rect.height));
      }

      const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
      const url = URL.createObjectURL(blob);

      try {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        await new Promise<void>((resolve, reject) => {
          img.onload = () => resolve();
          img.onerror = () => reject(new Error('Could not load SVG into image.'));
          img.src = url;
        });

        const canvas = document.createElement('canvas');
        canvas.width = width * scale;
        canvas.height = height * scale;
        const ctx = canvas.getContext('2d');
        if (!ctx) throw new Error('Canvas 2D context unavailable.');
        ctx.fillStyle = getComputedStyle(document.body).backgroundColor || '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.scale(scale, scale);
        ctx.drawImage(img, 0, 0, width, height);

        return await new Promise<Blob>((resolve, reject) => {
          canvas.toBlob((b) => b ? resolve(b) : reject(new Error('toBlob returned null')), 'image/png');
        });
      } finally {
        URL.revokeObjectURL(url);
      }
    }

    function toggleExamplesMenu(force?: boolean) {
      const willOpen = typeof force === 'boolean' ? force : examplesMenu.hidden;
      examplesMenu.hidden = !willOpen;
      examplesBtn.setAttribute('aria-expanded', String(willOpen));
    }

    function loadExample(key: string) {
      const ex = MERMAID_EXAMPLES.find((e) => e.key === key);
      if (!ex) return;
      input.value = ex.code;
      updateInputMeta();
      toggleExamplesMenu(false);
      render();
      input.focus();
    }

    function encodeShareUrl(): string {
      const text = input.value;
      if (!text) return window.location.origin + window.location.pathname;
      const compressed = LZString.compressToEncodedURIComponent(text);
      const theme = themeSelect.value;
      const params = new URLSearchParams();
      params.set('code', compressed);
      if (theme && theme !== 'default') params.set('theme', theme);
      return `${window.location.origin}${window.location.pathname}#${params.toString()}`;
    }

    async function copyShareUrl() {
      const url = encodeShareUrl();
      try {
        await navigator.clipboard.writeText(url);
        history.replaceState(null, '', url);
        setStatus('success', '✓ Share URL copied to clipboard');
      } catch {
        setStatus('error', 'Clipboard write failed.');
      }
    }

    function loadFromHash() {
      const hash = window.location.hash.startsWith('#') ? window.location.hash.slice(1) : '';
      if (!hash) return;
      const params = new URLSearchParams(hash);
      const code = params.get('code');
      const theme = params.get('theme') as Theme | null;
      if (code) {
        const decoded = LZString.decompressFromEncodedURIComponent(code);
        if (decoded) {
          input.value = decoded;
          updateInputMeta();
        }
      }
      if (theme && ['default', 'dark', 'forest', 'neutral'].includes(theme)) {
        themeSelect.value = theme;
      }
    }

    renderBtn.addEventListener('click', render);
    clearBtn.addEventListener('click', clearAll);
    copySvgBtn.addEventListener('click', copySvg);
    downloadSvgBtn.addEventListener('click', downloadSvg);
    downloadPngBtn.addEventListener('click', downloadPng);
    shareBtn.addEventListener('click', copyShareUrl);

    input.addEventListener('input', () => {
      updateInputMeta();
      scheduleRender();
    });
    themeSelect.addEventListener('change', () => {
      mermaidLib = null; // force re-init with new theme on next render
      render();
    });

    examplesBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleExamplesMenu();
    });
    examplesMenu.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const key = target.getAttribute('data-example-key');
      if (key) loadExample(key);
    });
    document.addEventListener('click', (e) => {
      if (!examplesMenu.hidden) {
        const t = e.target as HTMLElement;
        if (!examplesMenu.contains(t) && t !== examplesBtn) toggleExamplesMenu(false);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (!(e.ctrlKey || e.metaKey)) return;
      if (e.key === 'Enter') { e.preventDefault(); render(); }
      else if (e.shiftKey && (e.key === 'S' || e.key === 's')) { e.preventDefault(); downloadPng(); }
      else if (e.key === 's' || e.key === 'S') { e.preventDefault(); downloadSvg(); }
      else if (e.key === 'k' || e.key === 'K') { e.preventDefault(); clearAll(); }
      else if (e.key === '.') { e.preventDefault(); toggleExamplesMenu(); }
    });

    loadFromHash();
    updateInputMeta();
    if (input.value.trim()) {
      render();
    } else {
      setStatus('idle', 'Ready. Paste Mermaid syntax or pick an example.');
    }
    input.focus();
  </script>
</BaseLayout>
